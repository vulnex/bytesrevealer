{
  "name": "bytesrevealer",
  "version": "0.4",
  "description": "A Vue.js reverse engineering visualization tool",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "generate-favicon": "node scripts/generate-favicon.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,vue,css,json,md}\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,css,json,md}\" \"*.{js,json,md}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "buffer": "6.0.3",
    "crypto-js": "4.2.0",
    "file-type": "21.0.0",
    "iconv-lite": "0.7.0",
    "idb": "7.1.1",
    "jszip": "3.10.1",
    "kaitai-struct": "0.11.0",
    "libyara-wasm": "1.2.1",
    "pinia": "2.1.7",
    "vue": "3.5.29",
    "yaml": "2.3.4"
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@vitejs/plugin-vue": "5.0.3",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/eslint-plugin": "1.6.9",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.8.0",
    "globals": "17.3.0",
    "happy-dom": "20.6.0",
    "husky": "9.1.7",
    "js-yaml": "4.1.0",
    "lint-staged": "16.3.0",
    "prettier": "3.8.1",
    "terser": "5.44.0",
    "vite": "5.4.20",
    "vitest": "4.0.18",
    "vue-eslint-parser": "10.4.0"
  }
}
